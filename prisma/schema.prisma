// ============================================================================
//  SIMPLE ArCh — Schema do Banco de Dados (Prisma ORM)
// ----------------------------------------------------------------------------
//  Este arquivo é a "fonte da verdade" do nosso modelo de dados.
//  A partir dele o Prisma gera:
//    1) As migrations SQL (versionamento do banco)
//    2) Um Client TypeScript 100% tipado (autocompletar + segurança de tipos)
// ============================================================================

generator client {
  provider = "prisma-client-js"
  // "native" = ambiente local; "rhel-openssl-3.0.x" = runtime serverless da Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
//  USER
//  Representa uma pessoa autenticada via GitHub OAuth.
//  Guardamos o access_token do GitHub porque PRECISAMOS agir em nome do usuário
//  (ler issues, comentar em PRs, etc.). Esse token é SENSÍVEL → criptografado.
// ----------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?

  // --- Login local (email/senha) — alternativa ao GitHub OAuth ---
  // Hash bcrypt. Null para usuários que só entraram via GitHub.
  passwordHash String?

  // --- Identidade no GitHub (OPCIONAL: nem todo usuário conecta o GitHub) ---
  // githubId é o identificador IMUTÁVEL do GitHub (o username pode mudar; o id, não).
  // Por isso fazemos o "match" do usuário por githubId, nunca pelo login.
  githubId    String? @unique
  githubLogin String?

  // --- Credenciais OAuth do GitHub (NUNCA em texto puro) ---
  // Armazenamos o token criptografado (AES-256-GCM). Ver src/common/crypto.util.ts
  githubAccessToken  String? // ciphertext
  githubRefreshToken String? // ciphertext (GitHub Apps usam refresh; OAuth Apps clássicos não)
  githubTokenScope   String? // ex.: "repo,read:user"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relações ---
  // Um usuário pode ser dono de vários workspaces...
  ownedWorkspaces  Workspace[]        @relation("WorkspaceOwner")
  // ...e participar (como membro) de vários workspaces. Relação N:N via tabela pivô.
  memberships      WorkspaceMember[]
  // Tarefas que ele criou e tarefas atribuídas a ele.
  createdTasks     Task[]             @relation("TaskCreator")
  assignedTasks    Task[]             @relation("TaskAssignee")
  comments         Comment[]
  activityEvents   ActivityEvent[]
  notifications    Notification[]     @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")

  @@map("users")
}

// ----------------------------------------------------------------------------
//  WORKSPACE
//  É o "guarda-chuva" organizacional (equivale a um Team/Org no Linear).
//  Cada workspace pode estar vinculado a UM repositório do GitHub.
// ----------------------------------------------------------------------------
model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique // usado em URLs amigáveis: /w/acme-eng

  // --- Vínculo com o repositório do GitHub ---
  // Guardamos o ID numérico do repo (imutável) + o "fullName" (owner/repo) para exibição.
  githubRepoId       String? @unique
  githubRepoFullName String? // ex.: "acme/backend"

  // Dono do workspace (FK explícita para clareza).
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relações ---
  members WorkspaceMember[]
  tasks   Task[]
  events  ActivityEvent[]
  labels  Label[]

  @@map("workspaces")
}

// ----------------------------------------------------------------------------
//  WORKSPACE_MEMBER  (tabela pivô / join table)
//  Modela a relação N:N entre User e Workspace, MAS com atributos extras (o "role").
//  Quando uma relação N:N carrega dados próprios, ela DEVE virar um modelo explícito.
// ----------------------------------------------------------------------------
model WorkspaceMember {
  id String @id @default(cuid())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  // Um usuário não pode estar duas vezes no mesmo workspace.
  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

// ----------------------------------------------------------------------------
//  TASK
//  Nossa unidade de trabalho. O ponto-chave da integração: ela é MAPEADA
//  para uma issue do GitHub via githubIssueNumber.
// ----------------------------------------------------------------------------
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  // Prazo opcional. A UI destaca tasks vencidas comparando com "agora".
  dueDate     DateTime?

  // --- Mapeamento com o GitHub ---
  // O número da issue é único DENTRO de um repositório, não globalmente.
  // Por isso a unicidade é composta: (workspaceId + githubIssueNumber).
  githubIssueNumber Int?
  githubIssueId     String? // id global imutável da issue
  // Último PR que referenciou esta task (preenchido pelo webhook de pull_request).
  // Permite mostrar o CÓDIGO (diff, +/- linhas) da task direto no board.
  githubPrNumber    Int?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  labels    TaskLabel[]
  checklist ChecklistItem[]

  @@unique([workspaceId, githubIssueNumber])
  // Composto: toda consulta de board filtra por workspace primeiro, depois status.
  @@index([workspaceId, status])
  @@map("tasks")
}

// ----------------------------------------------------------------------------
//  LABEL  (etiqueta por workspace)
//  Cada workspace define suas próprias etiquetas coloridas; uma task pode ter
//  várias (relação N:N via TaskLabel).
// ----------------------------------------------------------------------------
model Label {
  id    String @id @default(cuid())
  name  String
  color String // hex, ex.: "#ef4444"

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks     TaskLabel[]
  createdAt DateTime    @default(now())

  // Nome único dentro do workspace (não globalmente).
  @@unique([workspaceId, name])
  @@map("labels")
}

// ----------------------------------------------------------------------------
//  TASK_LABEL  (join N:N entre Task e Label)
// ----------------------------------------------------------------------------
model TaskLabel {
  taskId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

// ----------------------------------------------------------------------------
//  CHECKLIST_ITEM  (subtarefa/checklist de uma task)
//  Itens simples marcáveis — decompõem uma task sem virar tasks separadas.
// ----------------------------------------------------------------------------
model ChecklistItem {
  id   String  @id @default(cuid())
  text String
  done Boolean @default(false)
  // Ordem manual dentro da task (arrastar/reordenar no futuro).
  order Int    @default(0)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId, order])
  @@map("checklist_items")
}

// ----------------------------------------------------------------------------
//  COMMENT
//  Comentário numa task — o canal de comunicação nativo da plataforma.
//  @menções ficam no próprio texto ("@nome"); o front destaca no render.
// ----------------------------------------------------------------------------
model Comment {
  id   String @id @default(cuid())
  body String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
  @@map("comments")
}

// ----------------------------------------------------------------------------
//  ACTIVITY_EVENT
//  Feed de atividade NATIVO do workspace (funciona sem GitHub).
//  Gravado em best-effort pelas mutações (task criada/movida, comentário,
//  membro entrou, PR vinculado via webhook) — nunca falha a operação principal.
// ----------------------------------------------------------------------------
model ActivityEvent {
  id   String       @id @default(cuid())
  type ActivityType

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Quem fez (null para eventos de sistema/webhook). SetNull: apagar o
  // usuário não apaga a história do workspace.
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  // Referência FRACA à task (sem FK): a task pode ser apagada e o evento fica.
  taskId  String?
  summary String // texto pronto para exibição, ex.: "moveu \"Login\" para IN_REVIEW"

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("activity_events")
}

// ----------------------------------------------------------------------------
//  NOTIFICATION
//  Notificação pessoal (menção, atribuição de task...). Distinta do
//  ActivityEvent (feed público do workspace): aqui é por USUÁRIO, com
//  estado de lida/não-lida, e dispara também em tempo real via WebSocket.
// ----------------------------------------------------------------------------
model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  message String

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  // Quem causou a notificação (null para eventos de sistema/webhook).
  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  workspaceId String
  // Referências FRACAS (sem FK): task/comentário podem ser apagados depois.
  taskId    String?
  commentId String?

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ----------------------------------------------------------------------------
//  ENUMS
//  Enums dão segurança de tipo e viram tipos nativos no PostgreSQL.
// ----------------------------------------------------------------------------
enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW // <- o webhook de Pull Request muda a task para cá automaticamente
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  TASK_CREATED
  TASK_MOVED
  TASK_ASSIGNED
  TASK_DELETED
  COMMENT_ADDED
  MEMBER_JOINED
  PR_LINKED
}

enum NotificationType {
  MENTION
  ASSIGNED
  COMMENT
}
