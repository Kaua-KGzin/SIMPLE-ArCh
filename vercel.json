{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  },
  "rewrites": [
    { "source": "/auth/github/:path*", "destination": "/api" },
    { "source": "/auth/login", "destination": "/api" },
    { "source": "/auth/register", "destination": "/api" },
    { "source": "/workspaces", "destination": "/api" },
    { "source": "/workspaces/:path*", "destination": "/api" },
    { "source": "/notifications", "destination": "/api" },
    { "source": "/notifications/:path*", "destination": "/api" },
    { "source": "/socket.io/:path*", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
